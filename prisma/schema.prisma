// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────

enum RequirementType {
  FUNCTIONAL
  NON_FUNCTIONAL
  BUSINESS_RULE
  USE_CASE
  USER_STORY
}

enum DeliverableType {
  USER_STORIES
  USE_CASES
  FUNCTIONAL_REQUIREMENTS
  NON_FUNCTIONAL_REQUIREMENTS
  DATA_DICTIONARY
  BUSINESS_RULES
  ENTITY_MAP
  FULL_DOCUMENT
}

// ─── MODELS ─────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]
}

model Client {
  id        String    @id @default(cuid())
  name      String
  industry  String?
  contact   String?
  email     String?
  phone     String?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]
}

model Project {
  id        String    @id @default(cuid())
  name      String
  description String? @db.Text

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions     Session[]
  deliverables Deliverable[]
}

model Session {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String?
  transcript  Json?     // Transcripción completa de la reunión
  notes       Json?     // Notas del editor tipo Notion
  audioUrl    String?   // URL del audio en Vercel Blob

  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  requirements  Requirement[]
  suggestions   AISuggestion[]
}

model Requirement {
  id        String          @id @default(cuid())
  sessionId String
  session   Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type      RequirementType
  title     String
  content   String          @db.Text
  category  String?         // roles, procesos, reglas, entidades, etc.
  priority  String?         // alta, media, baja
  metadata  Json?           // datos adicionales (actores, entidades relacionadas)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AISuggestion {
  id        String    @id @default(cuid())
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  question  String    @db.Text
  reason    String    @db.Text   // Por qué la IA sugiere esta pregunta
  category  String?              // Categoría del vacío detectado
  resolved  Boolean   @default(false)

  createdAt DateTime  @default(now())
}

model Deliverable {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      DeliverableType
  title     String
  content   Json            // Contenido estructurado del entregable
  version   String          @default("1.0")

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}
