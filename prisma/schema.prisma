// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────

enum RequirementType {
  FUNCTIONAL
  NON_FUNCTIONAL
  BUSINESS_RULE
  USE_CASE
  USER_STORY
}

enum DeliverableType {
  USER_STORIES
  USE_CASES
  FUNCTIONAL_REQUIREMENTS
  NON_FUNCTIONAL_REQUIREMENTS
  DATA_DICTIONARY
  BUSINESS_RULES
  ENTITY_MAP
  FULL_DOCUMENT
}

// ─── PRICING ENUMS ──────────────────────────────

enum ProfessionalLevel {
  JUNIOR
  SEMI_SENIOR
  SENIOR
  TECH_LEAD
  ARCHITECT
  SPECIALIST
}

enum EducationLevel {
  TECHNICAL
  BACHELOR
  ENGINEERING
  MASTER
  DOCTORATE
}

enum CostOfLiving {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum MarketScope {
  LOCAL
  LATAM
  NORTH_AMERICA
  EUROPE
  GLOBAL
}

enum ClientType {
  INDIVIDUAL
  STARTUP
  SME
  ENTERPRISE
  GOVERNMENT
  NGO
  UNIVERSITY
}

enum UrgencyLevel {
  VERY_URGENT
  URGENT
  NORMAL
  FLEXIBLE
}

enum ClarityLevel {
  VERY_CLEAR
  PARTIAL
  VERY_AMBIGUOUS
}

enum AvailabilityLevel {
  RESPONSIVE
  SLOW
  HARD_TO_REACH
}

enum ChangeLevel {
  LOW
  MEDIUM
  HIGH
}

enum BusinessValue {
  LOW
  MEDIUM
  HIGH
  TRANSFORMATIONAL
}

enum PaymentMethod {
  FULL_UPFRONT
  MILESTONES
  MONTHLY
  ON_DELIVERY
}

// ─── MODELS ─────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects        Project[]
  providerProfile ProviderProfile?
}

model Client {
  id        String    @id @default(cuid())
  name      String
  industry  String?
  contact   String?
  email     String?
  phone     String?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions     Session[]
  deliverables Deliverable[]
  context      ProjectContext?
}

model Session {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String?
  transcript  Json?     // Transcripción completa de la reunión
  notes       Json?     // Notas del editor tipo Notion
  audioUrl    String?   // URL del audio en Vercel Blob

  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  requirements  Requirement[]
  suggestions   AISuggestion[]
}

model Requirement {
  id        String          @id @default(cuid())
  sessionId String
  session   Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type      RequirementType
  title     String
  content   String          @db.Text
  category  String?         // roles, procesos, reglas, entidades, etc.
  priority  String?         // alta, media, baja
  metadata  Json?           // datos adicionales (actores, entidades relacionadas)

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AISuggestion {
  id        String    @id @default(cuid())
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  question  String    @db.Text
  reason    String    @db.Text   // Por qué la IA sugiere esta pregunta
  category  String?              // Categoría del vacío detectado
  resolved  Boolean   @default(false)

  createdAt DateTime  @default(now())
}

model Deliverable {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      DeliverableType
  title     String
  content   Json            // Contenido estructurado del entregable
  version   String          @default("1.0")

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// ─── PRICING: PROVIDER PROFILE (Capa 1 — se configura UNA VEZ) ───

model ProviderProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Tarifas por tipo de trabajo (USD/hr) ──
  rateGeneral    Float @default(35)
  rateFrontend   Float @default(30)
  rateBackend    Float @default(40)
  rateAI         Float @default(55)
  rateDesign     Float @default(25)
  rateConsulting Float @default(50)
  rateDevOps     Float @default(45)
  rateQA         Float @default(28)

  // ── Perfil profesional ──
  yearsExperience   Int               @default(1)
  professionalLevel ProfessionalLevel @default(SEMI_SENIOR)
  educationLevel    EducationLevel    @default(BACHELOR)
  specializations   String[]          @default([])
  certifications    String[]          @default([])
  completedProjects Int               @default(0)

  // ── Costos operativos mensuales ──
  internetCost      Float @default(0)
  electricityCost   Float @default(0)
  coworkingCost     Float @default(0)
  hostingCost       Float @default(0)
  licenseCost       Float @default(0)
  domainCostYearly  Float @default(0)
  accountingCost    Float @default(0)
  incomeTaxRate     Float @default(0)
  insuranceCost     Float @default(0)

  // ── Contexto de mercado ──
  providerCountry String      @default("Bolivia")
  mainCurrency    String      @default("USD")
  localCurrency   String      @default("Bs")
  exchangeRate    Float       @default(6.96)
  costOfLiving    CostOfLiving @default(LOW)
  marketScope     MarketScope  @default(LATAM)

  // ── Herramientas y productividad ──
  aiTools              String[] @default([])
  aiProductivityBoost  Float    @default(25)
  teamMembers          String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PRICING: PROJECT CONTEXT (Capa 2 — se configura POR PROYECTO) ───

model ProjectContext {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // ── Perfil del cliente ──
  clientType     ClientType @default(SME)
  clientIndustry String     @default("Tech")
  clientCountry  String     @default("")
  clientLanguage String     @default("es")
  clientTimezone String     @default("America/Guatemala")

  // ── Contexto del proyecto ──
  urgency             UrgencyLevel      @default(NORMAL)
  clientBudget        String            @default("MEDIUM")
  requirementsClarity ClarityLevel      @default(PARTIAL)
  clientAvailability  AvailabilityLevel @default(RESPONSIVE)
  changeProbability   ChangeLevel       @default(MEDIUM)
  businessValue       BusinessValue     @default(MEDIUM)
  estimatedMeetings   Int               @default(3)
  estimatedRevisions  Int               @default(3)

  // ── Condiciones comerciales ──
  profitMargin        Float         @default(25)
  negotiatedDiscount  Float         @default(0)
  isRecurringClient   Boolean       @default(false)
  isStrategicProject  Boolean       @default(false)
  paymentMethod       PaymentMethod @default(MILESTONES)
  upfrontPercentage   Float         @default(50)
  includedRevisions   Int           @default(3)
  supportMonths       Int           @default(1)
  warrantyMonths      Int           @default(3)
  trainingHours       Int           @default(4)
  codeOwnership       Boolean       @default(true)
  ndaRequired         Boolean       @default(false)
  lateDeliveryPenalty Boolean       @default(false)
  earlyDeliveryBonus  Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
